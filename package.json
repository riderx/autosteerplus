{
  "name": "autosteerplus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "fix:ios": "bun scripts/fix-ios-spm.mjs",
    "cap:sync": "bun run build && bunx cap sync && bun run fix:ios",
    "ios:open": "bun run cap:sync && bunx cap open ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.3.0",
    "vue": "^3.5.31"
  }
}
